{
  "name": "ai-delivery-workbench-v2",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "client",
    "shared"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "python -m uvicorn server_py.app:app --host 127.0.0.1 --port 4317",
    "dev:client": "npm --workspace client run dev",
    "build:shared": "npm --workspace @workbench/shared run build",
    "build": "npm --workspace shared run build && python -m compileall server_py && npm --workspace client run build",
    "typecheck": "npm --workspace shared run build && python -m compileall server_py && npm --workspace client run typecheck",
    "test:server": "python -m pytest server_py/tests -q",
    "test": "python -m pytest server_py/tests -q"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3"
  }
}
